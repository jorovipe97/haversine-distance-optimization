[
  {
    "label": "Debug json parse",
    "build": {
      "command": "cargo",
      "args": ["build", "--bin", "parse_json"],
    },
    "program": "$ZED_WORKTREE_ROOT/target/debug/parse_json",
    "args": ["--file", "data_2_haversine.json"],
    // sourceLanguages is required for CodeLLDB (not GDB) when using Rust
    "sourceLanguages": ["rust"],
    "request": "launch",
    "adapter": "CodeLLDB",
  },
]
